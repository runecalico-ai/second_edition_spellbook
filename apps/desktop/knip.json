{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["babel-plugin-react-compiler"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "warn",
    "exports": "warn",
    "nsExports": "warn",
    "classMembers": "warn",
    "types": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
